# Public URL of the studio-backend Cloud Run service.
# Baked into the bundle at build time. Leave empty to use same-origin requests
# (useful when fronting both services with a shared reverse proxy).
VITE_API_BASE_URL=https://studio-backend-xxxxx-uc.a.run.app

# Local dev port for `vite` / `vite preview`. Cloud Run overrides this.
PORT=5173

# Subpath the SPA is mounted at. Defaults to "/".
BASE_PATH=/
